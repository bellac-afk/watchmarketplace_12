generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  email String @unique
  password String
  name String
  phone String?
  avatar String?
  bio String?
  location String?

  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedAt DateTime?

  role UserRole @default(USER)

  ratingsAvg Float @default(0)
  ratingsCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?

  listings Listing[]
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  reviewsGiven Review[] @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")
  favorites Favorite[]
  searchHistory SearchHistory[]
  adminActivities AdminActivityLog[]

  @@index([email])
  @@index([role])
  @@index([verificationStatus])
  @@map("users")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model Brand {
  id String @id @default(uuid())
  name String @unique
  slug String @unique
  logoUrl String?
  description String?
  country String?
  foundedYear Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watches Watch[]

  @@map("brands")
}

model Watch {
  id String @id @default(uuid())
  brandId String
  model String
  collection String?
  reference String @unique
  referenceDisplay String?

  movementType MovementType?
  caseMaterial CaseMaterial?
  caseDiameter Float?
  caseThickness Float?
  waterResistance Int?
  powerReserve Int?
  crystal String?
  dialColor String?
  braceletMaterial String?
  braceletType String?
  claspType String?
  bezelMaterial String?
  functions String?
  complications String?
  lugWidth Float?
  weight Float?

  description String? @db.Text
  specifications Json?

  images WatchImage[]

  yearIntroduced Int?
  yearDiscontinued Int?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id])
  listings Listing[]

  @@index([brandId])
  @@index([reference])
  @@index([model])
  @@index([movementType])
  @@index([caseMaterial])
  @@index([caseDiameter])
  @@index([yearIntroduced])
  @@map("watches")
}

model WatchImage {
  id String @id @default(uuid())
  watchId String
  url String
  order Int @default(0)
  isMain Boolean @default(false)

  watch Watch @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@index([watchId])
  @@map("watch_images")
}

enum MovementType {
  AUTOMATIC
  QUARTZ
  MANUAL_WIND
  SPRING_DRIVE
  OTHER
}

enum CaseMaterial {
  STEEL
  GOLD
  ROSE_GOLD
  WHITE_GOLD
  PLATINUM
  TITANIUM
  CERAMIC
  CARBON
  TWO_TONE
  OTHER
}

model Listing {
  id String @id @default(uuid())

  watchId String
  userId String

  price Decimal @db.Decimal(12, 2)
  negotiable Boolean @default(false)
  originalPrice Decimal? @db.Decimal(12, 2)

  condition WatchCondition
  year Int?

  hasBox Boolean @default(false)
  hasPapers Boolean @default(false)
  hasOriginalStrap Boolean @default(false)
  additionalAccessories String?

  description String? @db.Text

  status ListingStatus @default(ACTIVE)

  location String?

  viewsCount Int @default(0)
  favoritesCount Int @default(0)

  bumpedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  soldAt DateTime?

  watch Watch @relation(fields: [watchId], references: [id])
  user User @relation(fields: [userId], references: [id])
  images ListingImage[]
  messages Message[]
  reviews Review[]
  favorites Favorite[]

  @@index([watchId])
  @@index([userId])
  @@index([status])
  @@index([price])
  @@index([condition])
  @@index([createdAt])
  @@index([bumpedAt])
  @@map("listings")
}

model ListingImage {
  id String @id @default(uuid())
  listingId String
  url String
  order Int @default(0)
  isMain Boolean @default(false)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

enum WatchCondition {
  NEW
  LIKE_NEW
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
  POOR
}

enum ListingStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD
  REMOVED
  REJECTED
}

model Message {
  id String @id @default(uuid())
  senderId String
  receiverId String
  listingId String?

  content String @db.Text
  read Boolean @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([listingId])
  @@index([read])
  @@map("messages")
}

model Review {
  id String @id @default(uuid())
  fromUserId String
  toUserId String
  listingId String

  rating Int
  comment String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromUser User @relation("ReviewsGiven", fields: [fromUserId], references: [id])
  toUser User @relation("ReviewsReceived", fields: [toUserId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@unique([fromUserId, listingId])
  @@index([toUserId])
  @@index([listingId])
  @@map("reviews")
}

model Favorite {
  id String @id @default(uuid())
  userId String
  listingId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorites")
}

model SearchHistory {
  id String @id @default(uuid())
  userId String
  query String
  filters Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("search_history")
}

model PriceHistory {
  id String @id @default(uuid())
  watchId String
  listingId String?
  price Decimal @db.Decimal(12, 2)
  condition WatchCondition

  createdAt DateTime @default(now())

  @@index([watchId])
  @@index([createdAt])
  @@map("price_history")
}

model AdminActivityLog {
  id String @id @default(uuid())
  adminId String
  action String
  description String
  metadata Json?

  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_activity_log")
}
