# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# reCAPTCHA
RECAPTCHA_SECRET_KEY=
